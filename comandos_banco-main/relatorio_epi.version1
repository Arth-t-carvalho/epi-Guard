    SETORES {
        int id PK
        varchar nome
        varchar sigla
        enum status
        text epis_json
    }

    FUNCIONARIOS {
        int id PK
        varchar nome
        int setor_id FK
        enum turno
        varchar foto_referencia
        enum status_epi
    }

    OCORRENCIAS {
        int id PK
        int funcionario_id FK
        datetime data_hora
        enum tipo
        boolean oculto
